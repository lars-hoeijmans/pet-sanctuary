#!/usr/bin/env bash
set -euo pipefail

API="${API_URL:-http://localhost:3001}"
LIMIT="${1:-8}"

snapshot=$(curl -s "$API/rooms/main")
echo "$snapshot" | jq -r --argjson limit "$LIMIT" '
  [.snapshot.events[]] | .[-($limit):] |
  group_by(.type) | map(
    if length == 1 and (.[0].payload.summary | type == "string") then
      "\(.[0].type): \(.[0].payload.summary)"
    else
      "\(.[0].type) x\(length)"
    end
  ) | if length == 0 then "(quiet)" else join(", ") end
'
