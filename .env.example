# Copy this file to `.env` and fill in your values.
# These are read server-side only (build scripts / dev proxy) and are never
# bundled into the client.

# Agent runtime
SANCTUARY_AI_ENABLED=true
SANCTUARY_AGENT_BACKEND=opencode
SANCTUARY_AGENT_MODEL=opencode/mimo-v2.5-free

# ElevenLabs — agent voices + background music
ELEVENLABS_API_KEY=sk_your_key_here
