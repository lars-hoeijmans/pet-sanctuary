DATABASE_URL=postgres://sanctuary:sanctuary@localhost:5432/pet_sanctuary
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_SANCTUARY_API_URL=http://localhost:3001
NEXT_PUBLIC_SANCTUARY_SOCKET_URL=http://localhost:3001/living-room

# Simulation loop interval in ms. Model-driven ticks are async; 15000 gives them
# room to finish before the next tick fires.
SIMULATION_TICK_MS=15000

# --- Real LLM agents (PRD §14 — never a paid per-token API) -----------------
# When "true", pets are driven by a REAL model through a locally-installed,
# already-authenticated agent CLI billed against a flat subscription (zero
# incremental cost). When "false", pets fall back to the deterministic policy.
SANCTUARY_AI_ENABLED=true

# Which local agent CLI backs the runtime: "opencode" (GitHub Copilot / OpenCode
# Zen free models) or "hermes" (the user's OpenAI Codex subscription, PRD §16).
SANCTUARY_AGENT_BACKEND=opencode

# Model for real task execution (runTask) and the lighter per-tick behaviour
# (decideAction). Both free via OpenCode Zen. mimo-v2.5-free is ~12x faster than
# deepseek-v4-flash-free (~8s vs ~100s for a task) — best for a snappy demo.
# deepseek tends to produce richer, more context-aware artifacts but is slow.
SANCTUARY_AGENT_MODEL=opencode/mimo-v2.5-free
SANCTUARY_AGENT_FAST_MODEL=opencode/mimo-v2.5-free
# Optional Hermes credential-pool provider override (e.g. "copilot").
# SANCTUARY_AGENT_PROVIDER=copilot

# Hard timeout (ms) per model call before falling back to deterministic. Free-tier
# models can take ~60-120s to generate a task artifact, so keep this generous.
SANCTUARY_LLM_TIMEOUT_MS=240000

# Where pets persist the artifacts their tasks produce (defaults to a temp dir).
# SANCTUARY_WORKSPACE_DIR=

# Without DATABASE_URL the API runs against an in-memory repository (no Postgres
# needed) — handy for quick local testing. Set it to enable durable persistence.
