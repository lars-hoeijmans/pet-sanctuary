DATABASE_URL=postgres://sanctuary:sanctuary@localhost:5432/pet_sanctuary
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_SANCTUARY_API_URL=http://localhost:3001
NEXT_PUBLIC_SANCTUARY_SOCKET_URL=http://localhost:3001/living-room

# Simulation loop interval in ms (deterministic ticks). Default 10000.
SIMULATION_TICK_MS=10000

# Gate for model-backed runtimes (AiSdk/Hermes). Keep "false" for the local-first
# MVP — when false no paid LLM API is ever called and pets stay deterministic.
# Only set "true" after a no-cost model route is verified (PRD §14).
SANCTUARY_AI_ENABLED=false

# Without DATABASE_URL the API runs against an in-memory repository (no Postgres
# needed) — handy for quick local testing. Set it to enable durable persistence.
